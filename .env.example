# Copy this to .env for local testing, and set these as Environment
# Variables in the Render dashboard for production.

# Supabase project settings -> API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Render sets PORT automatically; only needed for local dev
PORT=3000
